+
+/* 内部宿主也允许收缩 */
+.editor-host-inner {
+  flex: 1 1 auto !important;
+  min-height: 0 !important;
+}
+
+/* 提示面板不被裁剪 */
+.editor-height-chain .monaco-editor .monaco-hover,
+.editor-height-chain .monaco-editor .suggest-widget {
+  overflow: visible !important;
+}
+
+/* 隐藏调试卡片 */
+.debug-card { display: none !important; }
